{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "description": "A minimal Laravel business website template driven from config/site.php",
    "repository": {
        "type": "git",
        "url": "https://github.com/Temirt/business-template.git"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "start": "concurrently \"vite\" \"php artisan serve --port=8000\" \"cmd /c start http://127.0.0.1:8000\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
